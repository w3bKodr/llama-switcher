{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Llama Switcher",
  "version": "0.1.0",
  "identifier": "com.llamaswitcher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Llama Switcher",
        "label": "main",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "visible": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/window-icon.png": "window-icon.png",
      "icons/icon.ico": "desktop-icon.ico",
      "../hermes-skill/SKILL.md": "hermes-skill/SKILL.md",
      "../hermes-skill/scripts": "hermes-skill/scripts",
      "../hermes-skill/README.md": "hermes-skill/README.md"
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer/hooks.nsi"
      }
    }
  },
  "plugins": {}
}
